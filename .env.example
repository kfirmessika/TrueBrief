# LLM
GOOGLE_API_KEY=your_google_api_key

# Collector
TAVILY_API_KEY=your_tavily_api_key

# Database (Supabase)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# Paddle (Billing) — sign up at paddle.com, works worldwide including Israel
PADDLE_API_KEY=your_paddle_api_key
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
PADDLE_PRICE_PRO=pri_pro_id
PADDLE_PRICE_POWER=pri_power_id

# Clerk
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://.../.well-known/jwks.json
CLERK_ISSUER=https://...
CLERK_AUDIENCE=

# App
LOG_LEVEL=INFO
ENV=development

# CORS — comma-separated list of allowed frontend origins
# Development: http://localhost:3000
# Production: https://your-frontend.up.railway.app
FRONTEND_URL=http://localhost:3000

# Email Digest (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
DIGEST_FROM_EMAIL=briefs@truebrief.ai
